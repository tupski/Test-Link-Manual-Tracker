# ── Konfigurasi Link Tester v3 ────────────────────────────────────────
# Salin file ini menjadi .env dan sesuaikan nilainya

# Server
PORT=3000

# Supabase (dapatkan di https://app.supabase.com → Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# JWT Secret (string acak yang kuat)
JWT_SECRET=your_random_secret_here

# Password Admin (untuk login sebagai admin)
ADMIN_PASSWORD=your_admin_password
